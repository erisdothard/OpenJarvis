# =============================================================================
# OpenJarvis Environment Variables
# Copy to .env and fill in your values. Never commit this file.
# =============================================================================

# -- Cloud Model Providers ----------------------------------------------------
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# -- Speech / Realtime --------------------------------------------------------
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=

# -- LiveKit ------------------------------------------------------------------
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# -- Tools --------------------------------------------------------------------
TAVILY_API_KEY=

# -- Connector Secrets -------------------------------------------------------
# Facebook / Instagram (Meta Graph API)
OPENJARVIS_FACEBOOK_APP_SECRET=
OPENJARVIS_FACEBOOK_ACCESS_TOKEN=
OPENJARVIS_FACEBOOK_PAGE_ID=
OPENJARVIS_INSTAGRAM_ACCESS_TOKEN=
OPENJARVIS_INSTAGRAM_USER_ID=

# Spotify
OPENJARVIS_SPOTIFY_CLIENT_ID=
OPENJARVIS_SPOTIFY_CLIENT_SECRET=

# LinkedIn
OPENJARVIS_LINKEDIN_CLIENT_ID=
OPENJARVIS_LINKEDIN_CLIENT_SECRET=
